generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LegalType {
  privacidad
  terminos
}

enum CommentStatus {
  pending
  approved
  rejected
}

enum ThemePalette {
  warm
  night
  navidad
  octubre
}

enum StockReservationStatus {
  pending
  approved
  rejected
  expired
}

model InventorySupply {
  id           String                @id @default(cuid())
  nombre       String
  unidad       String
  precioTotal  Int
  cantidadTotal Float
  activo       Boolean               @default(true)
  recipeItems  InventoryRecipeItem[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model InventoryBaseProduct {
  id                   String                @id @default(cuid())
  nombre               String
  categoria            String
  precioBrutoReferencia Int                  @default(0)
  recipeItems          InventoryRecipeItem[]
  lots                 InventoryLot[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model InventoryRecipeItem {
  id            String               @id @default(cuid())
  baseProductId String
  supplyId      String
  cantidadUsada Float
  baseProduct   InventoryBaseProduct @relation(fields: [baseProductId], references: [id], onDelete: Cascade)
  supply        InventorySupply      @relation(fields: [supplyId], references: [id], onDelete: Restrict)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([baseProductId, supplyId])
}

model InventoryLot {
  id                  String                    @id @default(cuid())
  baseProductId       String
  serial              String                    @unique
  fechaFabricacion    DateTime
  fechaDisponible     DateTime
  cantidadFabricada   Int
  stockActual         Int
  precioBrutoUnitario Int
  porcentajeUtilidad  Int
  precioVentaUnitario Int
  baseProduct         InventoryBaseProduct      @relation(fields: [baseProductId], references: [id], onDelete: Restrict)
  assignments         InventoryShelfAssignment[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
}

model InventoryShelfAssignment {
  id              String      @id @default(cuid())
  lotId           String
  nombreEstanteria String
  cantidadAsignada Int
  lot             InventoryLot @relation(fields: [lotId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  nombre      String
  descripcion String?
  productos   Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id              String              @id @default(cuid())
  slug            String              @unique
  nombre          String
  descripcion     String
  precioReferencia Int
  imagenes        String[]
  activo          Boolean             @default(true)
  categoryId      String
  category        Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variantes       Variant[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model Variant {
  id            String   @id @default(cuid())
  productId     String
  nombreVariante String
  sku           String   @unique
  stockVirtual  Int      @default(0)
  stockMinimoAlerta Int  @default(0)
  precio        Int      @default(0) @map("precioDelta")
  imagenes      String[] @default([])
  descuentoActivo Boolean @default(false)
  descuentoPorcentaje Int @default(0) @map("descuentoValor")
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  reservas      StockReservation[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WhatsappOrder {
  id               String             @id @default(cuid())
  clienteNombre    String
  clienteCiudad    String
  telefono         String
  subtotalReferencia Int
  estado           String             @default("pending")
  mensaje          String
  items            WhatsappOrderItem[]
  reservas         StockReservation[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model WhatsappOrderItem {
  id              String         @id @default(cuid())
  orderId         String
  productId       String?
  variantId       String?
  nombreProducto  String
  nombreVariante  String?
  precioUnitario  Int
  cantidad        Int
  subtotal        Int
  order           WhatsappOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reservas        StockReservation[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model StockReservation {
  id         String                @id @default(cuid())
  orderId    String
  orderItemId String?
  variantId  String
  cantidad   Int
  status     StockReservationStatus @default(pending)
  resolvedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  order      WhatsappOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem  WhatsappOrderItem?    @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  variant    Variant               @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([variantId, status])
  @@index([orderId, status])
}

model ContactLead {
  id          String   @id @default(cuid())
  nombre      String
  correo      String
  telefono    String
  mensaje     String
  ciudad      String?
  source      String?
  createdAt   DateTime @default(now())
}

model BlogPost {
  id              String   @id @default(cuid())
  slug            String   @unique
  titulo          String
  autor           String
  extracto        String
  contenido       String
  imagen          String
  fechaPublicacion DateTime @default(now())
  comentarios     BlogComment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BlogComment {
  id         String        @id @default(cuid())
  postId     String
  mensaje    String
  status     CommentStatus @default(pending)
  post       BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  moderatedAt DateTime?
}

model FaqItem {
  id         String   @id @default(cuid())
  pregunta   String
  respuesta  String
  orden      Int      @default(1)
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LegalDocument {
  id            String    @id @default(cuid())
  tipo          LegalType @unique
  contenido     String
  fechaVigencia DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SiteContent {
  id                String   @id @default("main")
  nosotrosTitulo    String
  nosotrosHistoria  String
  nosotrosPromesa   String
  heroTitulo        String?
  heroDescripcion   String?
  updatedAt         DateTime @updatedAt
}

model SiteTheme {
  id                 String       @id @default(cuid())
  slug               String       @unique
  nombre             String
  palette            ThemePalette @default(warm)
  backgroundImageUrl String?
  heroImageUrl       String?
  isActive           Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}
